# PR Source — GitHub
GITHUB_PAT=ghp_your_token_here

# PR Source — Azure DevOps
AZURE_ORG=your-org
AZURE_PAT=your_azure_pat_here

# LLM — Groq (fast, free tier available — https://console.groq.com)
GROQ_API_KEY=gsk_...

# LLM — OpenAI
OPENAI_API_KEY=sk-...

# LLM — Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# LLM — Ollama (no key needed, just URL)
OLLAMA_BASE_URL=http://localhost:11434

# Defaults
DEFAULT_PROVIDER=github
DEFAULT_LLM=ollama
DEFAULT_MODEL=llama3.1:8b
